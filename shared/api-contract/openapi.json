{
  "openapi": "3.1.0",
  "info": {
    "title": "Ouroboros API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/regions/{start}/{end}": {
      "get": {
        "summary": "Retrieve a genome region",
        "parameters": [
          {
            "name": "start",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "end",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Genome region response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./schemas/GenomeRegionResponse.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/annotations": {
      "get": {
        "summary": "List annotation features",
        "responses": {
          "200": {
            "description": "Annotation list response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./schemas/AnnotationListResponse.schema.json"
                }
              }
            }
          }
        }
      }
    }
  }
}
